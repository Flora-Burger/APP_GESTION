# Configuration de l'application FLORA
NOM_ENTREPRISE=Grup CST & Batmar S.L.
LOGO_URL=/static/img/logo.png

# Local (Windows) : SQLite
DATABASE_URL=sqlite:///./data/flora.db

# Vercel / production : PostgreSQL (Neon, Supabase ou Vercel Postgres)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

DEBUG=true
JWT_SECRET=changez-cette-cle-secrete-en-production-flora
JWT_EXPIRATION_MINUTES=480

# true obligatoire en HTTPS (Vercel le force automatiquement)
COOKIE_SECURE=false

# Vercel Blob : creer un store dans le dashboard Vercel > Storage > Blob
# BLOB_READ_WRITE_TOKEN=
